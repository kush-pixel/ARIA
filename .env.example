# ARIA v4.3 Environment Variables
# Copy to backend/.env and fill in real values
# NEVER commit backend/.env

# PostgreSQL (Supabase)
DATABASE_URL=
# Anthropic API (Layer 3 LLM summary only)
ANTHROPIC_API_KEY=
# Application
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=generate_a_random_32_char_string_here

# Demo settings
DEMO_MODE=true
BRIEFING_TRIGGER=manual